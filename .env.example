# zooplus Assistant — copy to `.env` and adjust (never commit `.env`)

# Retrieval: hybrid | vector
ZOOPLUS_RETRIEVAL_MODE=hybrid

# Answer synthesis: template (default, no API) | opencode (free-tier via OpenCode CLI)
ZOOPLUS_SYNTHESIS_MODE=template

# OpenCode model from your account (`opencode models` to list)
ZOOPLUS_OPENCODE_MODEL=opencode-go/qwen3.6-plus
ZOOPLUS_OPENCODE_TIMEOUT=90

# Optional: isolate credentials under the repo (directory is gitignored)
# Run once: opencode auth login  (with OPENCODE_DATA_DIR set)
# ZOOPLUS_OPENCODE_DATA_DIR=.opencode/data
# ZOOPLUS_OPENCODE_CONFIG_DIR=.opencode
