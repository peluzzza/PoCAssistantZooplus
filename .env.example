# zooplus Assistant — copy to `.env` and adjust (never commit `.env`)

# Retrieval: hybrid | vector
ZOOPLUS_RETRIEVAL_MODE=hybrid

# Agentic routing (internal OpenCode — shopper only sees zooplus Assistant)
ZOOPLUS_INTENT_MODE=agentic
ZOOPLUS_SYNTHESIS_MODE=opencode
ZOOPLUS_SOCIAL_SYNTHESIS=agentic
ZOOPLUS_AGENT_CASCADE=1
# ZOOPLUS_FAST_INTENT=0  # keep off in prod; tests may enable regex hints

# OpenCode model from your account (`opencode models` to list)
# Use config-cli (no MCP) so `opencode run` does not hang when API is down
ZOOPLUS_OPENCODE_MODEL=opencode/deepseek-v4-flash-free
ZOOPLUS_OPENCODE_TIMEOUT=45

# Project-local credentials (gitignored) — run scripts/setup_opencode_local.ps1
ZOOPLUS_OPENCODE_DATA_DIR=.opencode/data
ZOOPLUS_OPENCODE_CONFIG_DIR=.opencode/config-cli
