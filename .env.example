# zooplus Assistant — copy to `.env` or run: .\scripts\setup_wizard.ps1
# NEVER commit `.env` (gitignored)

# =============================================================================
# PROFILE A — Template (no OpenCode) — wizard option 1
# =============================================================================
# ZOOPLUS_INTENT_MODE=oracle
# ZOOPLUS_SYNTHESIS_MODE=template
# ZOOPLUS_AGENT_CASCADE=0

# =============================================================================
# PROFILE B — OpenCode agentic (free LLMs) — wizard option 2  [active below]
# =============================================================================
ZOOPLUS_INTENT_MODE=agentic
ZOOPLUS_SYNTHESIS_MODE=opencode
ZOOPLUS_SOCIAL_SYNTHESIS=agentic
ZOOPLUS_AGENT_CASCADE=1

# Latency: intent-agent first; conductor only when ZOOPLUS_CONDUCTOR_INTENT=1
ZOOPLUS_CONDUCTOR_INTENT=0
ZOOPLUS_INTENT_AGENT_CHAIN=zooplus-intent-agent
ZOOPLUS_SOCIAL_AGENT_CHAIN=zooplus-social-agent
ZOOPLUS_SYNTHESIS_AGENT_CHAIN=zooplus-synthesis
ZOOPLUS_CONDUCTOR_AGENT_CHAIN=zooplus-conductor

# English-only routing shortcuts (tests/CI). Production agentic = any language via OpenCode.
# ZOOPLUS_FAST_INTENT=1

# In-process TTL cache (instant repeat queries). Redis optional for multi-instance scale-out.
ZOOPLUS_CACHE=1
ZOOPLUS_CACHE_BACKEND=memory
# ZOOPLUS_CACHE_BACKEND=redis
# ZOOPLUS_REDIS_URL=redis://127.0.0.1:6379/0
ZOOPLUS_CACHE_TTL_SECONDS=600
ZOOPLUS_CACHE_MAX_ENTRIES=128

# Agentic intent repair via catalog lexicon (off by default — conductor decides).
# ZOOPLUS_INTENT_REPAIR=1

# Retrieval: hybrid | vector
ZOOPLUS_RETRIEVAL_MODE=hybrid

# OpenCode — fallback when an agent has no `model` in opencode.json
ZOOPLUS_OPENCODE_MODEL=opencode-go/deepseek-v4-flash
# Per-agent LLMs: edit `.opencode/config-cli/opencode.json` (OpenCode Go speed ladder).
# Optional env overrides (role or agent):
# ZOOPLUS_SOCIAL_MODEL=opencode-go/deepseek-v4-flash
# ZOOPLUS_AGENT_MODEL_ZOOPLUS_LOGIC_WORKER=opencode-go/minimax-m2.7
ZOOPLUS_SOCIAL_AGENT_CHAIN=zooplus-social-agent
ZOOPLUS_SOCIAL_ALLOW_FALLBACK=0
ZOOPLUS_OPENCODE_TIMEOUT=15

# Project-local credentials (gitignored) — wizard runs setup_opencode_local.ps1
ZOOPLUS_OPENCODE_DATA_DIR=.opencode/data
ZOOPLUS_OPENCODE_CONFIG_DIR=.opencode/config-cli

# Dev server port (run_dev.ps1)
ZOOPLUS_DEV_PORT=8090
