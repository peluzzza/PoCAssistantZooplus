# zooplus Assistant — copy to `.env` and adjust (never commit `.env`)

# Retrieval: hybrid | vector
ZOOPLUS_RETRIEVAL_MODE=hybrid

# Intent routing: agentic (OpenCode LLM — recommended) | oracle (CI/local fixture)
ZOOPLUS_INTENT_MODE=agentic

# Answer synthesis: template (fast) | opencode (sociable prose via OpenCode CLI)
ZOOPLUS_SYNTHESIS_MODE=opencode

# Social/decline: agentic (OpenCode subagents — default) | template (CI emergency only)
ZOOPLUS_SOCIAL_SYNTHESIS=agentic

# OpenCode model from your account (`opencode models` to list)
ZOOPLUS_OPENCODE_MODEL=opencode-go/deepseek-v4-flash
ZOOPLUS_OPENCODE_TIMEOUT=25

# Project-local credentials (gitignored) — run scripts/setup_opencode_local.ps1
# or: set OPENCODE_DATA_DIR=.opencode\data && opencode auth login
ZOOPLUS_OPENCODE_DATA_DIR=.opencode/data
ZOOPLUS_OPENCODE_CONFIG_DIR=.opencode

# Retry across OpenCode subagents before heuristic fallback (1=on)
ZOOPLUS_AGENT_CASCADE=1
# Optional comma-separated override, e.g. zooplus-intent-agent,zooplus-topic-guard,zooplus-conductor
# ZOOPLUS_INTENT_AGENT_CHAIN=
