{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "zooplus_assistant": {
      "type": "remote",
      "url": "http://127.0.0.1:8080/mcp",
      "enabled": false,
      "timeout": 5000
    }
  },
  "tools": {
    "zooplus_*": false
  },
  "agent": {
    "zooplus-conductor": {
      "mode": "primary",
      "description": "Agentic-first shop orchestrator (intent → social | catalog pipeline)",
      "model": "opencode/mimo-v2.5-free",
      "tools": {
        "zooplus_topic_check": true,
        "zooplus_constraints_get": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "zooplus-intent-agent": "allow",
          "zooplus-social-agent": "allow",
          "zooplus-topic-guard": "allow",
          "zooplus-rag-worker": "allow",
          "zooplus-logic-worker": "allow",
          "zooplus-synthesis": "allow"
        }
      }
    },
    "zooplus-intent-agent": {
      "mode": "subagent",
      "description": "Default-deny intent router (conversational | catalog | decline)",
      "model": "opencode-go/deepseek-v4-flash",
      "tools": {
        "zooplus_topic_check": true,
        "zooplus_constraints_get": true
      }
    },
    "zooplus-social-agent": {
      "mode": "subagent",
      "description": "Sociable replies without catalog retrieval",
      "model": "opencode/mimo-v2.5-free",
      "tools": {
        "zooplus_constraints_get": true
      }
    },
    "zooplus-topic-guard": {
      "mode": "subagent",
      "description": "MCP topic_check compat (prefer intent-agent)",
      "model": "opencode-go/minimax-m2.5",
      "tools": {
        "zooplus_topic_check": true
      }
    },
    "zooplus-rag-worker": {
      "mode": "subagent",
      "description": "RAG retrieval worker scoped by site_id",
      "model": "opencode-go/deepseek-v4-flash",
      "tools": {
        "zooplus_catalog_search": true
      }
    },
    "zooplus-logic-worker": {
      "mode": "subagent",
      "description": "Recommendation shaping and ranking constraints",
      "model": "opencode-go/qwen3.6-plus",
      "tools": {
        "zooplus_catalog_search": true
      }
    },
    "zooplus-rag-pipeline": {
      "mode": "subagent",
      "description": "Offline EDA and ingest operations",
      "tools": {
        "zooplus_catalog_search": false
      }
    },
    "zooplus-synthesis": {
      "mode": "subagent",
      "description": "Grounded sociable answer from retrieved products",
      "model": "opencode/deepseek-v4-flash-free",
      "tools": {
        "zooplus_constraints_get": true
      }
    }
  }
}
