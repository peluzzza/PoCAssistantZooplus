{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "zooplus_assistant": {
      "type": "remote",
      "url": "http://127.0.0.1:8080/mcp",
      "enabled": false,
      "timeout": 5000
    }
  },
  "tools": {
    "zooplus_*": false,
    "glob": false,
    "grep": false,
    "read": false,
    "write": false,
    "edit": false,
    "bash": false
  },
  "agent": {
    "zooplus-conductor": {
      "mode": "primary",
      "description": "Invisible v2.0 orchestrator (strong LLM — decides stream ticks)",
      "model": "opencode-go/minimax-m2.7",
      "tools": {
        "zooplus_topic_check": true,
        "zooplus_constraints_get": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "zooplus-intent-agent": "allow",
          "zooplus-social-agent": "allow",
          "zooplus-topic-guard": "allow",
          "zooplus-rag-worker": "allow",
          "zooplus-logic-worker": "allow",
          "zooplus-synthesis": "allow"
        }
      }
    },
    "zooplus-intent-agent": {
      "mode": "subagent",
      "description": "Default-deny intent router (conversational | catalog | decline)",
      "model": "opencode-go/mimo-v2.5",
      "tools": {
        "zooplus_topic_check": true,
        "zooplus_constraints_get": true
      }
    },
    "zooplus-social-agent": {
      "mode": "subagent",
      "description": "Go #1 deepseek-v4-flash — sociable replies without catalog",
      "model": "opencode-go/deepseek-v4-flash",
      "tools": {
        "zooplus_constraints_get": true
      }
    },
    "zooplus-topic-guard": {
      "mode": "subagent",
      "description": "Go #4 qwen3.7-plus — topic / scope guard",
      "model": "opencode-go/qwen3.7-plus",
      "tools": {
        "zooplus_topic_check": true
      }
    },
    "zooplus-rag-worker": {
      "mode": "subagent",
      "description": "Go #5 deepseek-v4-pro — RAG retrieval worker scoped by site_id",
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "zooplus_catalog_search": true
      }
    },
    "zooplus-logic-worker": {
      "mode": "subagent",
      "description": "Recommendation shaping and ranking constraints",
      "model": "opencode-go/minimax-m2.7",
      "tools": {
        "zooplus_catalog_search": true
      }
    },
    "zooplus-rag-pipeline": {
      "mode": "subagent",
      "description": "Offline EDA and ingest operations",
      "tools": {
        "zooplus_catalog_search": false
      }
    },
    "zooplus-synthesis": {
      "mode": "subagent",
      "description": "Go #7 qwen3.6-plus — grounded catalog answer",
      "model": "opencode-go/qwen3.6-plus",
      "tools": {
        "zooplus_constraints_get": true
      }
    }
  }
}
