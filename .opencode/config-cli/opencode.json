{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {},
  "tools": {
    "zooplus_*": false,
    "glob": false,
    "grep": false,
    "read": false,
    "write": false,
    "edit": false,
    "bash": false
  },
  "agent": {
    "zooplus-conductor": {
      "mode": "primary",
      "description": "Go #6 minimax-m2.7 — invisible v2.0 orchestrator",
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "task": {
          "*": "deny",
          "zooplus-intent-agent": "allow",
          "zooplus-social-agent": "allow",
          "zooplus-topic-guard": "allow",
          "zooplus-rag-worker": "allow",
          "zooplus-logic-worker": "allow",
          "zooplus-synthesis": "allow"
        }
      }
    },
    "zooplus-intent-agent": {
      "mode": "subagent",
      "description": "Go #2 mimo-v2.5 — JSON intent router",
      "model": "opencode-go/mimo-v2.5"
    },
    "zooplus-social-agent": {
      "mode": "subagent",
      "description": "Go #1 deepseek-v4-flash — lowest latency social",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "zooplus-topic-guard": {
      "mode": "subagent",
      "description": "Go #4 qwen3.7-plus — scope guard",
      "model": "opencode-go/qwen3.7-plus"
    },
    "zooplus-rag-worker": {
      "mode": "subagent",
      "description": "Go #5 deepseek-v4-pro — retrieval worker",
      "model": "opencode-go/deepseek-v4-pro"
    },
    "zooplus-logic-worker": {
      "mode": "subagent",
      "description": "Go #6 minimax-m2.7 — rank + cap fallback",
      "model": "opencode-go/minimax-m2.7"
    },
    "zooplus-synthesis": {
      "mode": "subagent",
      "description": "Go #7 qwen3.6-plus — grounded catalog prose",
      "model": "opencode-go/qwen3.6-plus"
    }
  }
}
