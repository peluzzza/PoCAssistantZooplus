{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {},
  "tools": {
    "zooplus_*": false,
    "glob": false,
    "grep": false,
    "read": false,
    "write": false,
    "edit": false,
    "bash": false
  },
  "agent": {
    "zooplus-conductor": {
      "mode": "primary",
      "description": "Fast shop orchestrator (intent → social | catalog)",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "task": {
          "*": "deny",
          "zooplus-intent-agent": "allow",
          "zooplus-social-agent": "allow",
          "zooplus-topic-guard": "allow",
          "zooplus-rag-worker": "allow",
          "zooplus-logic-worker": "allow",
          "zooplus-synthesis": "allow"
        }
      }
    },
    "zooplus-intent-agent": {
      "mode": "subagent",
      "description": "Intent router — default deny",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "zooplus-social-agent": {
      "mode": "subagent",
      "description": "Social replies — no catalog (flash for low latency)",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "zooplus-topic-guard": {
      "mode": "subagent",
      "description": "Topic / quality guard",
      "model": "opencode-go/minimax-m2.5"
    },
    "zooplus-rag-worker": {
      "mode": "subagent",
      "description": "Site-scoped retrieval worker",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "zooplus-logic-worker": {
      "mode": "subagent",
      "description": "Rank and cap recommendations",
      "model": "opencode-go/qwen3.6-plus"
    },
    "zooplus-synthesis": {
      "mode": "subagent",
      "description": "Grounded catalog answer",
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
